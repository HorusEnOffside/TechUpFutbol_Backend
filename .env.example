# ==========================
# App ports
# ==========================
HTTP_PORT=8080
HTTPS_PORT=8443

# ==========================
# SSL/TLS
# ==========================
SSL_ENABLED=true
SSL_KEY_STORE=classpath:certs/techup-local.p12
SSL_KEY_STORE_PASSWORD=changeit
SSL_KEY_ALIAS=techup-local

# ==========================
# Basic auth (solo desarrollo)
# ==========================
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=changeit-admin

# ==========================
# JWT
# ==========================
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRATION=3600000

# ==========================
# CORS
# Lista separada por comas
# ==========================
CORS_ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000,http://127.0.0.1:3000
